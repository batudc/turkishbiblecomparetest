  "5": {
    "4": "“Baş Çoban”: İsa Mesih."
  },
  "2": {
    "9": "“Kral”: Tanrı.",
    "13": "“Kral”: Burada Roma İmparatoru anlamına gelir.",
    "25": "“Canlarınızın Çobanı ve Gözetmeni”: İsa Mesih."
  },
  "3": {
    "18": "“Öldü”: Birçok Grekçe elyazmasında, “Acı çekti” diye geçer.",
    "20": "“Suyla kurtuldu” ya da “sudan sağ salim çıktı”."
  },
  "1": {
    "11": "“Hangi zamanı” ya da “kimi”."
  }
}